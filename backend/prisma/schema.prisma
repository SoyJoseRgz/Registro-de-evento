generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  config    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users             User[]
  events            Event[]
  registrationFields RegistrationField[]
  registrations     Registration[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  email        String
  passwordHash String   @map("password_hash")
  name         String
  role         String   @default("organizer") // admin | organizer | assistant
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checkIns CheckIn[]

  @@unique([tenantId, email])
  @@map("users")
}

model Event {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  title       String
  slug        String
  description String?
  eventType   String   @map("event_type") // conference|workshop|meetup|webinar|other
  location    String?
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  capacity    Int
  status      String   @default("draft") // draft|published|cancelled|completed
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registrations Registration[]
  checkIns      CheckIn[]

  @@unique([tenantId, slug])
  @@map("events")
}

model RegistrationField {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  fieldName    String   @map("field_name")
  fieldType    String   @map("field_type") // text|email|phone|number|select|checkbox|textarea
  options      String?
  isRequired   Boolean  @default(false) @map("is_required")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("registration_fields")
}

model Registration {
  id            String   @id @default(uuid())
  eventId       String   @map("event_id")
  tenantId      String   @map("tenant_id")
  attendeeName  String   @map("attendee_name")
  attendeeEmail String   @map("attendee_email")
  attendeePhone String?  @map("attendee_phone")
  customFields  String?  @map("custom_fields")
  qrCode        String?  @map("qr_code")
  status        String   @default("pending") // pending|confirmed|cancelled|checked_in
  registeredAt  DateTime @default(now()) @map("registered_at")
  checkedInAt   DateTime? @map("checked_in_at")

  event   Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checkIns CheckIn[]

  @@map("registrations")
}

model CheckIn {
  id             String   @id @default(uuid())
  registrationId String   @map("registration_id")
  eventId        String   @map("event_id")
  checkedInBy    String   @map("checked_in_by")
  checkedInAt    DateTime @default(now()) @map("checked_in_at")
  method         String   @default("qr") // qr|manual

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [checkedInBy], references: [id])

  @@map("check_ins")
}
